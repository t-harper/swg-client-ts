{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs-site",
  "tsconfig": "tsconfig.json",
  "name": "@swg/ts-client — Docs portal",
  "includeVersion": true,
  "readme": "docs/docs-portal-readme.md",
  "projectDocuments": [
    "docs/scripting-quickref.md",
    "docs/scripting.md",
    "docs/scripting-cookbook.md",
    "docs/lifecycle.md",
    "docs/wire-spec.md",
    "docs/wire-reference.md",
    "docs/adding-a-message.md"
  ],
  "categorizeByGroup": true,
  "searchInComments": true,
  "navigationLinks": {
    "Repo": "https://github.com/t-harper/swg-client-ts",
    "Wire reference": "documents/Wire-message_reference.html",
    "Scripting quickref": "documents/Scripting_quickref.html"
  },
  "sidebarLinks": {
    "Scripting cookbook": "documents/Scripting_cookbook.html",
    "Lifecycle": "documents/Lifecycle.html",
    "Adding a message": "documents/Adding_a_message.html"
  },
  "excludeInternal": true,
  "excludePrivate": true,
  "skipErrorChecking": true,
  "hideGenerator": true,
  "highlightLanguages": [
    "bash",
    "c",
    "cpp",
    "diff",
    "json",
    "javascript",
    "shell",
    "ts",
    "tsx",
    "typescript",
    "yaml"
  ],
  "intentionallyNotExported": [
    "TradeAcceptOptions",
    "Posture",
    "MessageClassRef",
    "SayOptions",
    "MessageDispatcher",
    "MessageDecoder",
    "ObjControllerSubtypeDecoder",
    "BaselineRegistry",
    "SoeConnection",
    "ClientPermissionsMessage",
    "TranscriptSource",
    "ICodec",
    "IByteStream",
    "IReadIterator",
    "GameNetworkMessage",
    "AttributePair",
    "ScenarioFn",
    "DeltaRegistry",
    "WearableEntryValue",
    "CreatureObjectEffect",
    "PlayerAndShipPair",
    "PackedBuffValue",
    "TangibleObjectClientServerBaseline",
    "TangibleObjectClientServerNpBaseline",
    "CreatureObjectClientServerBaseline",
    "CreatureObjectFirstParentClientServerBaseline",
    "CreatureObjectFirstParentClientServerNpBaseline",
    "CreatureObjectSharedBaseline",
    "PlayerObjectClientServerBaseline",
    "PlayerObjectClientServerNpBaseline"
  ]
}
