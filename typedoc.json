{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs-site",
  "tsconfig": "tsconfig.json",
  "name": "@swg/ts-client — Docs portal",
  "includeVersion": true,
  "readme": "docs/docs-portal-readme.md",
  "projectDocuments": [
    "docs/player-handbook.md",
    "docs/scripting-quickref.md",
    "docs/views-reference.md",
    "docs/actions-reference.md",
    "docs/wire-reference.md",
    "docs/scripting-cookbook.md",
    "docs/examples-walkthrough.md",
    "docs/lifecycle.md",
    "docs/wire-spec.md",
    "docs/adding-a-message.md"
  ],
  "categorizeByGroup": true,
  "searchInComments": true,
  "navigationLinks": {
    "Repo": "https://github.com/t-harper/swg-client-ts",
    "Quickstart": "documents/Scripting_quickref.html",
    "Always-on views": "documents/Always-on_views.html",
    "Actions": "documents/Actions.html"
  },
  "sidebarLinks": {
    "Player Handbook (start here)": "documents/Player_Handbook.html",
    "Wire reference": "documents/Wire-message_reference.html",
    "Scripting cookbook": "documents/Scripting_cookbook.html",
    "Examples walkthrough": "documents/Examples_walkthrough.html",
    "Lifecycle (internals)": "documents/lifecycle.html",
    "Wire spec (internals)": "documents/wire-spec.html",
    "Adding a message (internals)": "documents/adding-a-message.html"
  },
  "excludeInternal": true,
  "excludePrivate": true,
  "skipErrorChecking": true,
  "hideGenerator": true,
  "highlightLanguages": [
    "bash",
    "c",
    "cpp",
    "diff",
    "json",
    "javascript",
    "shell",
    "ts",
    "tsx",
    "typescript",
    "yaml"
  ],
  "intentionallyNotExported": [
    "TradeAcceptOptions",
    "Posture",
    "MessageClassRef",
    "SayOptions",
    "MessageDispatcher",
    "MessageDecoder",
    "ObjControllerSubtypeDecoder",
    "BaselineRegistry",
    "SoeConnection",
    "ClientPermissionsMessage",
    "TranscriptSource",
    "ICodec",
    "IByteStream",
    "IReadIterator",
    "GameNetworkMessage",
    "AttributePair",
    "ScenarioFn",
    "DeltaRegistry",
    "WearableEntryValue",
    "CreatureObjectEffect",
    "PlayerAndShipPair",
    "PackedBuffValue",
    "TangibleObjectClientServerBaseline",
    "TangibleObjectClientServerNpBaseline",
    "CreatureObjectClientServerBaseline",
    "CreatureObjectFirstParentClientServerBaseline",
    "CreatureObjectFirstParentClientServerNpBaseline",
    "CreatureObjectSharedBaseline",
    "PlayerObjectClientServerBaseline",
    "PlayerObjectClientServerNpBaseline"
  ]
}
