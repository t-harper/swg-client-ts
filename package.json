{
  "name": "@swg/ts-client",
  "version": "0.1.0",
  "type": "module",
  "description": "Headless TypeScript SWG wire-compatible client for CI/testing/automation. See ../swg-main/CLAUDE.md for context.",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.1.2",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "swg-ts-cli": "./dist/bin/swg-ts-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests bin",
    "lint:fix": "biome check --write src tests bin",
    "typecheck": "tsc --noEmit",
    "cli": "node --import tsx bin/swg-ts-cli.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^24.0.0",
    "fast-check": "^4.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
